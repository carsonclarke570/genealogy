# Example dev environment for the app. Copy to app/.env.local and adjust.
# Defaults assume the docker-compose services at the repo root (`docker compose up -d`).

# Postgres (the docker-compose `db` service).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genealogy

# Shared password gate (stand-in until Auth.js lands). AUTH_SECRET signs the session.
AUTH_SECRET=dev-secret-change-me
SITE_PASSWORD=family

# Embeddings — self-hosted TEI (the docker-compose `embeddings` service).
# Leave empty to run hybrid search in lexical-only (keyword) mode.
EMBEDDINGS_URL=http://localhost:8080
# EMBEDDING_DIM=384            # must equal the migration's vector(N)
# EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5   # informational

# Geocoding — self-hosted Photon (the docker-compose `geocoder` service).
# Leave empty to run the location picker with archive-place autocomplete only.
GEOCODER_URL=http://localhost:2322

# Media object storage (the docker-compose `minio` service). In production these
# point at a Railway managed Bucket instead — same S3 API.
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=family-media
# STORAGE_REGION=us-east-1
