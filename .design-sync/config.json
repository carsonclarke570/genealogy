{
  "pkg": "@family-archive/ui",
  "globalName": "FamilyArchiveUI",
  "projectId": "2d2340c7-33d4-49f1-b39c-1f54f83c4f20",
  "shape": "package",
  "buildCmd": "npm run build",
  "srcDir": "src",
  "tsconfig": "tsconfig.json",
  "cssEntry": "dist/family-archive.css",
  "extraFonts": [".design-sync/fonts/brand-fonts.css"],
  "runtimeFontPrefixes": ["Cascadia"],
  "readmeHeader": ".design-sync/conventions.md",
  "docsDir": ".design-sync/docs",
  "componentSrcMap": {
    "ProvenanceMark": "src/components/Provenance.tsx",
    "SourceCiteDialog": "src/components/Provenance.tsx"
  },
  "overrides": {
    "ProvenanceMark": { "cardMode": "column" },
    "SourceCiteDialog": { "cardMode": "single", "primaryStory": "LinkSource" },
    "Card": { "cardMode": "column" },
    "Checkbox": { "cardMode": "column" },
    "EmptyState": { "cardMode": "column" },
    "RadioGroup": { "cardMode": "column" },
    "Tabs": { "cardMode": "column" },
    "Textarea": { "cardMode": "column" },
    "Toast": { "cardMode": "column" },
    "Dialog": { "cardMode": "single", "primaryStory": "ConfirmDelete" },
    "Menu": { "cardMode": "single", "primaryStory": "Default" },
    "Timeline": { "cardMode": "column", "primaryStory": "LifeEvents" },
    "MultiSelect": { "cardMode": "column", "primaryStory": "FilterByPerson" },
    "Combobox": { "cardMode": "column", "primaryStory": "PickRelative" },
    "ToastViewport": { "cardMode": "single", "primaryStory": "Stack" },
    "DateField": { "cardMode": "column", "primaryStory": "KnownToTheMonth" },
    "Icon": { "cardMode": "column", "primaryStory": "Library" },
    "SearchInput": { "cardMode": "column", "primaryStory": "WithQuery" },
    "Slider": { "cardMode": "column", "primaryStory": "YearScrubber" },
    "DetailRow": { "cardMode": "column", "primaryStory": "RecordFacts" },
    "ClickableCard": { "cardMode": "column", "primaryStory": "PersonSummary" },
    "FileDropzone": { "cardMode": "column", "primaryStory": "Document" },
    "LocationField": { "cardMode": "column", "primaryStory": "Selected" },
    "MediaPreview": { "cardMode": "column", "primaryStory": "Gallery" },
    "MultiCombobox": { "cardMode": "column", "primaryStory": "TagPeople" },
    "ProvField": { "cardMode": "column", "primaryStory": "ConfidenceStates" },
    "ProvLabel": { "cardMode": "column", "primaryStory": "States" },
    "ProvLocationField": { "cardMode": "column", "primaryStory": "Birthplace" },
    "AnchoredPopover": { "cardMode": "single", "primaryStory": "BelowTrigger", "viewport": "360x300" },
    "Stepper": { "cardMode": "column", "primaryStory": "MidFlow" },
    "DocViewer": { "cardMode": "single", "primaryStory": "Certificate", "viewport": "520x420" },
    "Accordion": { "cardMode": "column", "primaryStory": "Open" },
    "Callout": { "cardMode": "column", "primaryStory": "Tones" },
    "PersonRow": { "cardMode": "column", "primaryStory": "Relationships" }
  }
}
