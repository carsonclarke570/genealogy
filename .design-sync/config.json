{
  "pkg": "@family-archive/ui",
  "globalName": "FamilyArchiveUI",
  "projectId": "2d2340c7-33d4-49f1-b39c-1f54f83c4f20",
  "shape": "package",
  "buildCmd": "npm run build",
  "srcDir": "src",
  "tsconfig": "tsconfig.json",
  "cssEntry": "dist/family-archive.css",
  "extraFonts": [".design-sync/fonts/brand-fonts.css"],
  "runtimeFontPrefixes": ["Cascadia"],
  "readmeHeader": ".design-sync/conventions.md",
  "componentSrcMap": {
    "ProvenanceMark": "src/components/Provenance.tsx",
    "SourceCiteDialog": "src/components/Provenance.tsx"
  },
  "overrides": {
    "ProvenanceMark": { "cardMode": "column" },
    "SourceCiteDialog": { "cardMode": "single", "primaryStory": "LinkSource" },
    "Card": { "cardMode": "column" },
    "Checkbox": { "cardMode": "column" },
    "EmptyState": { "cardMode": "column" },
    "RadioGroup": { "cardMode": "column" },
    "Tabs": { "cardMode": "column" },
    "Textarea": { "cardMode": "column" },
    "Toast": { "cardMode": "column" },
    "Dialog": { "cardMode": "single", "primaryStory": "ConfirmDelete" },
    "Menu": { "cardMode": "single", "primaryStory": "Default" },
    "Timeline": { "cardMode": "column", "primaryStory": "LifeEvents" },
    "MultiSelect": { "cardMode": "column", "primaryStory": "FilterByPerson" },
    "ToastViewport": { "cardMode": "single", "primaryStory": "Stack" },
    "DateField": { "cardMode": "column", "primaryStory": "KnownToTheMonth" }
  }
}
